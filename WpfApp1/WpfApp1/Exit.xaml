<Window x:Class="WpfApp1.Exit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Exit" Height="450" Width="800">
    <Grid OpacityMask="#FFB75A5A">
        <Grid.Background>
            <ImageBrush ImageSource="/Exit.jpg"/>
        </Grid.Background>
        <Button x:Name="button" Content="ДА" HorizontalAlignment="Left" Height="60" Margin="139,268,0,0" VerticalAlignment="Top" Width="196" Click="button_Click" Background="#FF1AF508" Foreground="Black" FontSize="36"/>
        <Button x:Name="button1" Content="НЕТ" HorizontalAlignment="Left" Height="60" Margin="496,268,0,0" VerticalAlignment="Top" Width="195" Click="button1_Click" Background="#FFDC1E1E" FontSize="36"/>
        <Label x:Name="label" Content="ВЫЙТИ!?" HorizontalAlignment="Center" Margin="0,119,0,0" VerticalAlignment="Top" Foreground="#FF0010FF" Width="214" FontSize="48" Background="Transparent"/>

    </Grid>
</Window>
