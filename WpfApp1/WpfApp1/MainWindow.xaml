<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid RenderTransformOrigin="0.472,0.547">
        <Grid.Background>
            <ImageBrush ImageSource="/3F3F3F4 (1).jpg"/>
        </Grid.Background>
        <Button x:Name="СТАТЬ_РАВШАНОМ" Content="СТАТЬ РАВШАНОМ" HorizontalAlignment="Left" Height="41" Margin="42,293,0,0" VerticalAlignment="Top" Width="199" Command="{Binding Effect, ElementName=Exit}" Click="СТАТЬ_РАВШАНОМ_Click">
            <Button.Effect>
                <DropShadowEffect/>
            </Button.Effect>
        </Button>
        <Label x:Name="ЦУАУП" Content="СИМУЛЯТОР РАВШАНА" HorizontalAlignment="Left" Height="35" Margin="26,41,0,0" VerticalAlignment="Top" Width="231" Background="Transparent" Foreground="Red" FontWeight="Bold" FontSize="18"/>
        <Button x:Name="Exit" Content="ПУКНУТЬ" HorizontalAlignment="Left" Height="35" Margin="179,339,0,0" VerticalAlignment="Top" Width="62" Cursor="Help" Click="Exit_Click"/>
        <Button x:Name="donat" HorizontalAlignment="Left" Height="58" Margin="710,339,0,0" VerticalAlignment="Top" Width="57" Click="donat_Click" Background="White" Content="+" FontSize="24"/>
    </Grid>
</Window>
