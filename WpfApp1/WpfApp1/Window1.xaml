<Window x:Class="WpfApp1.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800"
		ResizeMode="CanMinimize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="/boll-104101239.jpg"/>
        </Grid.Background>
        <Label x:Name="label" Content="Вы: Равшан" HorizontalAlignment="Left" Height="25" Margin="10,10,0,0" VerticalAlignment="Top" Width="76"/>
        <Label x:Name="label1" Content="Задача: Собирать хлопок" HorizontalAlignment="Left" Height="23" Margin="10,35,0,0" VerticalAlignment="Top" Width="161"/>
        <Button x:Name="collect" Content="Собирать" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" Width="133" Background="#FFD4FB6F" Height="22" Click="Collect_Click"/>
        <Button x:Name="chill" Content="Отдохнуть" HorizontalAlignment="Left" Margin="10,298,0,0" VerticalAlignment="Top" Background="#FFFAFFEC" Click="otdyhat_Click" Width="133" Height="20"/>
        <Button x:Name="sell" Content="Продать" HorizontalAlignment="Left" Margin="10,243,0,0" VerticalAlignment="Top" Background="#FFF92C2C" Click="sell_Click" Width="133" Height="20"/>
        <Button x:Name="store" Content="Магазин" HorizontalAlignment="Left" Margin="10,271,0,0" VerticalAlignment="Top" Background="#FFFAFFEC" Click="magazin_Click" Width="133" Height="20"/>
        <Button x:Name="dead" Content="Сдаться" HorizontalAlignment="Left" Margin="10,369,0,0" VerticalAlignment="Top" Width="133" Background="#FFF92C2C" Height="22" Click="dead_Click"/>
        <!--<TextBlock Text="Здоровье: 100" FontSize="12" Foreground="#FF28A41E" Name="txtHealth" Margin="0,77,710,332" Width="90"/>
        <TextBlock Text=" Энергия: 100" FontSize="12" Foreground="#FFCE8821" Name="txtEnergy" Margin="0,58,710,357" Width="90"/>
        <TextBlock Text="Деньги: 0" FontSize="12" Foreground="#FF026908" Name="txtMoney" Margin="0,68,376,342" HorizontalAlignment="Right" Height="25"/> -->
        <TextBlock Name="txtCotton" Text="0" FontSize="20" FontWeight="Bold" Foreground="Black" Padding="10" VerticalAlignment="Top" TextAlignment="Center" Margin="257,6,258,0"/>
        <Label Content="грамм" HorizontalAlignment="Center" Margin="0,-3,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="txtEnergy" Content="100" HorizontalAlignment="Left" Height="26" Margin="756,22,0,0" VerticalAlignment="Top" Width="29" Background="Transparent" Foreground="#FFFF7806"/>
        <Label x:Name="txtHealth" Content="100" HorizontalAlignment="Left" Height="24" Margin="756,35,0,0" VerticalAlignment="Top" Width="32" Foreground="#FFFF0808"/>
        <Label x:Name="txtMoney" Content="0" HorizontalAlignment="Left" Height="27" Margin="750,2,0,0" VerticalAlignment="Top" Width="40" Background="Transparent" Foreground="#FF48C72E"/>
        <Label x:Name="label2" Content="Деньги:" HorizontalAlignment="Left" Height="24" Margin="706,2,0,0" VerticalAlignment="Top" Width="56" Foreground="#FF48C72E"/>
        <Label x:Name="label2_Копировать" Content="Энергия:" HorizontalAlignment="Left" Height="24" Margin="704,20,0,0" VerticalAlignment="Top" Width="59" Foreground="#FFFF7806"/>
        <Label x:Name="label2_Копировать1" Content="Здоровье:" HorizontalAlignment="Left" Height="24" Margin="698,34,0,0" VerticalAlignment="Top" Width="65" Foreground="#FFFF0808"/>



    </Grid>
</Window>
